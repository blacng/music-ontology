    :hasMember :DavidGilmour, :RogerWaters, :RichardWright, :NickMason ;
    .
:DavidGilmour a :Musician ; rdfs:label "David Gilmour"@en ; :hasInstrument :Guitar, :Voice .
:RogerWaters a :Musician ; rdfs:label "Roger Waters"@en ; :hasInstrument :Bass, :Voice .
:RichardWright a :Musician ; rdfs:label "Richard Wright"@en ; :hasInstrument :Synthesizer .
:NickMason a :Musician ; rdfs:label "Nick Mason"@en ; :hasInstrument :Drums .

# --- Performers for the works that lacked one ---
:BohemianRhapsody :performedBy :Queen .
:SmokeOnTheWater :performedBy :DeepPurple .
:TheDarkSideOfTheMoon :performedBy :PinkFloyd .
:ImagineSong :performedBy :JohnLennon .
:CryMeARiver :performedBy :JulieLondon .

# --- Cross-artist collaborations (collaboratesWith, CQ-2) ---
# Documented real-world collaborations between agents already in the catalog.
# :collaboratesWith is owl:SymmetricProperty, so each pairing is asserted once;
# queries traverse both directions via :collaboratesWith|^:collaboratesWith.
# (:PaulMcCartney :collaboratesWith :JohnLennon is already asserted above.)
:DavidBowie :collaboratesWith :FreddieMercury .      # "Under Pressure" (1981)
:DavidBowie :collaboratesWith :JohnLennon .          # "Fame" (1975)
:DavidBowie :collaboratesWith :MickJagger .          # "Dancing in the Street" (1985)
:MichaelJackson :collaboratesWith :PaulMcCartney .   # "Say Say Say" / "The Girl Is Mine" (1982–83)
:MichaelJackson :collaboratesWith :MickJagger .      # "State of Shock" (1984)
:PaulMcCartney :collaboratesWith :KanyeWest .        # "FourFiveSeconds" / "Only One" (2015)

###############################################################################
# v2.2 — PLACE TYPES, CONTINENT ROLL-UP, ACTIVITY INTERVALS, HISTORICAL EVENTS
###############################################################################

# --- Place-type category individuals (gist:Category pattern; :broaderPlaceType
#     orders them finest → coarsest so "at nation level or higher" queries work) ---
:City      a :PlaceType ; rdfs:label "City"@en      ; :broaderPlaceType :Region .
:Region    a :PlaceType ; rdfs:label "Region"@en    ; :broaderPlaceType :Nation .
:Nation    a :PlaceType ; rdfs:label "Nation"@en    ; :broaderPlaceType :Continent .
:Continent a :PlaceType ; rdfs:label "Continent"@en .

# --- Continents + nation → continent roll-up (enables same-continent discovery, CQ-14) ---
:Europe       a :Place ; :hasPlaceType :Continent ; rdfs:label "Europe"@en .
:NorthAmerica a :Place ; :hasPlaceType :Continent ; rdfs:label "North America"@en .

:England       :locatedIn :Europe .
:France        :locatedIn :Europe .
:Austria       :locatedIn :Europe .
:Germany       :locatedIn :Europe .
:UnitedStates  :locatedIn :NorthAmerica .
:Jamaica       :locatedIn :NorthAmerica .

# Ireland — added for the Irish War of Independence event below.
:Ireland a :Place ; :hasPlaceType :Nation ; rdfs:label "Ireland"@en ; :locatedIn :Europe .

# --- Artist activity intervals (canonical era signal, CQ-13). :activeUntil is
#     omitted for still-active artists (open interval). ---
:TheBeatles    :activeFrom "1960"^^xsd:gYear ; :activeUntil "1970"^^xsd:gYear .
:Nirvana       :activeFrom "1987"^^xsd:gYear ; :activeUntil "1994"^^xsd:gYear .
:PaulMcCartney :activeFrom "1957"^^xsd:gYear .
:BobDylan      :activeFrom "1961"^^xsd:gYear .
:DavidBowie    :activeFrom "1962"^^xsd:gYear ; :activeUntil "2016"^^xsd:gYear .
:TaylorSwift   :activeFrom "2004"^^xsd:gYear .

# --- Historical events (dated intervals + location; artist links are derived, CQ-15) ---
:AmericanCivilRightsMovement a :HistoricalEvent ;
    rdfs:label "American Civil Rights Movement"@en ;
    gist:actualStartDate "1954-05-17"^^xsd:date ;
    gist:actualEndDate   "1968-04-11"^^xsd:date ;
    :locatedIn :UnitedStates ;
    .

:IrishWarOfIndependence a :HistoricalEvent ;
    rdfs:label "Irish War of Independence"@en ;
    gist:actualStartDate "1919-01-21"^^xsd:date ;
    gist:actualEndDate   "1921-07-11"^^xsd:date ;
    :locatedIn :Ireland ;
    .

###############################################################################
# v2.3 — WORK COLLECTIONS (L1: curated grouping of related works, plain relation)
###############################################################################

# Collection-type category individuals (gist:Category pattern, like genres/place-types).
:Anthology          a :CollectionType ; rdfs:label "Anthology"@en .
:BoxSet             a :CollectionType ; rdfs:label "Box Set"@en .
:Compilation        a :CollectionType ; rdfs:label "Compilation"@en .
:ThematicCollection a :CollectionType ; rdfs:label "Thematic Collection"@en .

# An illustrative curated collection: three #1 rock anthems (cf. CQ-10), grouped by theme.
:GreatestRockAnthems a :WorkCollection ;
    rdfs:label "Greatest Rock Anthems"@en ;
    gist:isCategorizedBy :ThematicCollection ;
    :collects :HeyJude, :BohemianRhapsody, :ImagineSong ;
    .
