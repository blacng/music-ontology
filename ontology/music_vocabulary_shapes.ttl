@prefix : <https://www.somusicvocabulary.org/music#> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

###############################################################################
# SHACL SHAPES — Comprehensive Music Vocabulary
# Artefact 3 (SHACL Generation), against the post-Artefact-4 model.
#
# Severity policy:
#   sh:Violation (default) — type/datatype/structural constraints the model
#                            asserts; data MUST conform. Type-checks are ALWAYS
#                            Violations (kept in their own property shape).
#   sh:Warning            — completeness expectations a recommender wants but
#                            the current sparse prototype data may not yet meet
#                            (these double as test-data targets for Artefact 5).
###############################################################################

:musicPrefixes
    sh:declare [ sh:prefix "m" ; sh:namespace "https://www.somusicvocabulary.org/music#"^^xsd:anyURI ] ;
    sh:declare [ sh:prefix "gist" ; sh:namespace "https://w3id.org/semanticarts/ns/ontology/gist/"^^xsd:anyURI ] .

###############################################################################
# NODE SHAPES
###############################################################################

:MusicalArtistShape a sh:NodeShape ;
    sh:targetClass :MusicalArtist ;
    # --- type / structural (Violation) ---
    sh:property [ sh:path :hasGenre ; sh:class :MusicGenre ;
        sh:message "hasGenre must point to a :MusicGenre." ] ;
    sh:property [ sh:path :originatesFrom ; sh:class :Place ; sh:maxCount 1 ;
        sh:message "An artist's origin must be a single :Place." ] ;
    sh:property [ sh:path :isSignedTo ; sh:class :RecordLabel ;
        sh:message "isSignedTo must point to a :RecordLabel (CQ-3)." ] ;
    sh:property [ sh:path :collaboratesWith ; sh:class :MusicalAgent ;
        sh:message "collaboratesWith must relate one music-making agent to another (CQ-2)." ] ;
    sh:property [ sh:path :hasAward ; sh:class :MusicAward ;
        sh:message "hasAward must point to a :MusicAward (CQ-7)." ] ;
    sh:property [ sh:path :bornOn ; sh:datatype xsd:date ; sh:maxCount 1 ;
        sh:message "bornOn must be a single xsd:date." ] ;
    sh:property [ sh:path :startsCareerIn ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "startsCareerIn must be a single xsd:gYear." ] ;
    sh:property [ sh:path :activeFrom ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "activeFrom must be a single xsd:gYear (CQ-13)." ] ;
    sh:property [ sh:path :activeUntil ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "activeUntil must be a single xsd:gYear (CQ-13)." ] ;
    # An artist's activity interval must be well-ordered: activeFrom ≤ activeUntil.
    sh:sparql [
        sh:message "activeFrom must not be later than activeUntil (CQ-13 activity interval)." ;
        sh:prefixes :musicPrefixes ;
        sh:select """
            SELECT $this WHERE {
                $this m:activeFrom ?f ; m:activeUntil ?u .
                FILTER(xsd:integer(STR(?f)) > xsd:integer(STR(?u)))
            }
        """ ;
    ] ;
    # --- completeness (Warning) ---
    sh:property [ sh:path :hasGenre ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "A musical artist should have at least one genre (needed for genre discovery, CQ-1/CQ-9)." ] ;
    .

:BandShape a sh:NodeShape ;
    sh:targetClass :Band ;
    sh:property [ sh:path :hasMember ; sh:class :Musician ;
        sh:message "Every band member must be a :Musician (type check)." ] ;
    sh:property [ sh:path :hasMember ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "A band should have at least one member (enables band-member crossover, CQ-11)." ] ;
    .

:MusicianShape a sh:NodeShape ;
    sh:targetClass :Musician ;
    sh:property [ sh:path :hasInstrument ; sh:class :MusicalInstrument ;
        sh:message "hasInstrument must point to a :MusicalInstrument." ] ;
    # A musician should play an instrument (singing counts via :Voice), unless they conduct.
    sh:or ( [ sh:path :hasInstrument ; sh:minCount 1 ] [ sh:class :Conductor ] ) ;
    sh:severity sh:Warning ;
    sh:message "A musician should play at least one instrument — singing counts via :Voice — unless they are a conductor (CQ-5)." ;
    .

:SongShape a sh:NodeShape ;
    sh:targetClass :Song ;
    sh:property [ sh:path :performedBy ; sh:class :MusicalArtist ;
        sh:message "performedBy must point to a :MusicalArtist." ] ;
    sh:property [ sh:path :writtenBy ; sh:class :Lyricist ;
        sh:message "writtenBy must point to a :Lyricist." ] ;
    sh:property [ sh:path :belongsToAlbum ; sh:class :Album ; sh:maxCount 1 ;
        sh:message "A song belongs to at most one album." ] ;
    sh:property [ sh:path :releasedIn ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "releasedIn must be a single xsd:gYear." ] ;
    sh:property [ sh:path :hasDuration ; sh:datatype xsd:decimal ; sh:maxCount 1 ;
        sh:message "hasDuration must be a single xsd:decimal (seconds)." ] ;
    sh:property [ sh:path :peaksAt ; sh:datatype xsd:integer ; sh:minInclusive 1 ; sh:maxCount 1 ;
        sh:message "peaksAt must be a single positive chart position (CQ-10)." ] ;
    sh:property [ sh:path :performedBy ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "A song should state who performs it." ] ;
    .

:AlbumShape a sh:NodeShape ;
    sh:targetClass :Album ;
    sh:property [ sh:path :performedBy ; sh:class :MusicalArtist ;
        sh:message "performedBy must point to a :MusicalArtist." ] ;
    sh:property [ sh:path :releasedBy ; sh:class :RecordLabel ;
        sh:message "releasedBy must point to a :RecordLabel." ] ;
    sh:property [ sh:path :producedBy ; sh:class :MusicProducer ;
        sh:message "producedBy must point to a :MusicProducer (CQ-8)." ] ;
    sh:property [ sh:path :hasTrack ; sh:class :Song ;
        sh:message "hasTrack must point to a :Song." ] ;
    sh:property [ sh:path :releasedIn ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "releasedIn must be a single xsd:gYear." ] ;
    sh:property [ sh:path :performedBy ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "An album should state the artist who performs it." ] ;
    .

:CompositionShape a sh:NodeShape ;
    sh:targetClass :Composition ;
    sh:property [ sh:path :composedBy ; sh:class :Composer ;
        sh:message "composedBy must point to a :Composer." ] ;
    sh:property [ sh:path :composedBy ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "A composition should state its composer." ] ;
    .

# --- Genre shapes (gist:Category pattern) ---

:MusicGenreShape a sh:NodeShape ;
    sh:targetClass :MusicGenre ;
    sh:property [ sh:path :hasBroaderGenre ; sh:class :MusicGenre ;
        sh:message "hasBroaderGenre must relate a genre to another genre." ] ;
    .

:TopLevelGenreShape a sh:NodeShape ;
    sh:targetClass :TopLevelGenre ;
    sh:property [ sh:path :hasBroaderGenre ; sh:maxCount 0 ;
        sh:message "A top-level genre must not have a broader genre (it is a root of the hierarchy)." ] ;
    .

# --- Geography shapes (gist:Category place-typing) ---

# Places must be categorized by exactly one :PlaceType, which must be a :PlaceType.
:PlaceShape a sh:NodeShape ;
    sh:targetClass :Place ;
    sh:property [ sh:path :hasPlaceType ; sh:class :PlaceType ; sh:maxCount 1 ;
        sh:message "A place must carry at most one :PlaceType (city/region/nation/continent)." ] ;
    sh:property [ sh:path :locatedIn ; sh:class :Place ;
        sh:message "locatedIn must point to another :Place." ] ;
    .

# City-level places must roll up to a containing place so regional discovery works
# (CQ-12/CQ-14). Targeted via SPARQL constraint (not a class) now that granularity is
# category-typed rather than subclassed.
:CityRollupShape a sh:NodeShape ;
    sh:targetClass :Place ;
    sh:sparql [
        sh:message "Every city must roll up to a containing place (its country) so regional discovery works (CQ-12/CQ-14)." ;
        sh:prefixes :musicPrefixes ;
        sh:select """
            SELECT $this WHERE {
                $this m:hasPlaceType m:City .
                FILTER NOT EXISTS { $this m:locatedIn ?container }
            }
        """ ;
    ] ;
    .

:PlaceTypeShape a sh:NodeShape ;
    sh:targetClass :PlaceType ;
    sh:property [ sh:path :broaderPlaceType ; sh:class :PlaceType ; sh:maxCount 1 ;
        sh:message "broaderPlaceType must point to the next coarser :PlaceType." ] ;
    .

# --- Historical-event shape (CQ-15) ---

:HistoricalEventShape a sh:NodeShape ;
    sh:targetClass :HistoricalEvent ;
    sh:property [ sh:path gist:actualStartDate ; sh:datatype xsd:date ; sh:maxCount 1 ; sh:minCount 1 ;
        sh:message "A historical event must have exactly one gist:actualStartDate (xsd:date)." ] ;
    sh:property [ sh:path gist:actualEndDate ; sh:datatype xsd:date ; sh:maxCount 1 ; sh:minCount 1 ;
        sh:message "A historical event must have exactly one gist:actualEndDate (xsd:date)." ] ;
    sh:property [ sh:path :locatedIn ; sh:class :Place ; sh:minCount 1 ;
        sh:message "A historical event must be situated in a :Place (needed for came-of-age origin match, CQ-15)." ] ;
    # The event interval must be well-ordered: start ≤ end.
    sh:sparql [
        sh:message "A historical event's gist:actualStartDate must not be later than its gist:actualEndDate." ;
        sh:prefixes :musicPrefixes ;
        sh:select """
            SELECT $this WHERE {
                $this gist:actualStartDate ?s ; gist:actualEndDate ?e .
                FILTER(?s > ?e)
            }
        """ ;
    ] ;
    .

# --- Work-collection shape (L1: curated grouping of related works) ---

:WorkCollectionShape a sh:NodeShape ;
    sh:targetClass :WorkCollection ;
    sh:property [ sh:path :collects ; sh:class :MusicalWork ;
        sh:message "collects must point to a :MusicalWork." ] ;
    sh:property [ sh:path gist:isCategorizedBy ; sh:class :CollectionType ; sh:maxCount 1 ;
        sh:message "A work collection carries at most one :CollectionType (anthology/box set/…)." ] ;
    sh:property [ sh:path :collects ; sh:minCount 1 ; sh:severity sh:Warning ;
        sh:message "A work collection should collect at least one work (enables collection browse, CQ-16)." ] ;
    .

###############################################################################
# CAREER-ONSET CONSTRAINT (replaces the rdfs:domain axioms dropped in v2.4.0)
###############################################################################

# :startsCareerIn / :activeFrom / :activeUntil used to carry `rdfs:domain :MusicalArtist`.
# In RDFS a domain is an *inference rule* — "anything with this property IS a :MusicalArtist" —
# not the constraint we meant. It silently retyped producers, conductors and non-artist musicians
# as :MusicalArtist (visible once check_shacl.py enabled inference). The domains are gone; this
# shape states the intended rule in the language built for it.
#
# Careers belong to music-making agents (:MusicalAgent covers artists, bands, orchestras via
# :Band, and musicians incl. conductors) and to producers (:MusicProducer sits under gist:Person,
# outside :MusicalAgent).
:CareerOnsetShape a sh:NodeShape ;
    sh:targetSubjectsOf :startsCareerIn, :activeFrom, :activeUntil ;
    sh:property [ sh:path :startsCareerIn ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "startsCareerIn must be a single xsd:gYear." ] ;
    sh:property [ sh:path :activeFrom ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "activeFrom must be a single xsd:gYear (CQ-13)." ] ;
    sh:property [ sh:path :activeUntil ; sh:datatype xsd:gYear ; sh:maxCount 1 ;
        sh:message "activeUntil must be a single xsd:gYear (CQ-13)." ] ;
    sh:or ( [ sh:class :MusicalAgent ] [ sh:class :MusicProducer ] ) ;
    sh:message "Career-onset years belong to a music-making agent (:MusicalAgent) or a :MusicProducer." ;
    .

###############################################################################
# CQ-DERIVED SPARQL CONSTRAINT
###############################################################################

# CQ-10: a song with a chart peak position must say which chart it charted in.
:ChartConsistencyShape a sh:NodeShape ;
    sh:targetClass :Song ;
    sh:sparql [
        sh:message "A song with a peak chart position (:peaksAt) must also state the chart via :chartedIn (CQ-10)." ;
        sh:prefixes :musicPrefixes ;
        sh:select """
            SELECT $this WHERE {
                $this m:peaksAt ?pos .
                FILTER NOT EXISTS { $this m:chartedIn ?chart }
            }
        """ ;
    ] ;
    .
