###############################################################################
# MUSIC VOCABULARY — TBOX (model: classes, properties, ontology header)
#
# Generated by scripts/split_tbox_abox.py. Instance data (the ABox) lives in
# music_catalog_data.ttl. At triplestore ingest this file is loaded into the
# named graph <https://www.somusicvocabulary.org/music/tbox>.
###############################################################################

@prefix : <https://www.somusicvocabulary.org/music#> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

###############################################################################
# ONTOLOGY DECLARATION
###############################################################################

:MusicVocabulary a owl:Ontology ;
    rdfs:label "Comprehensive Music Vocabulary"@en ;
    rdfs:comment "A comprehensive vocabulary for describing music concepts, works, artists, instruments, and relationships."@en ;
    owl:versionInfo "2.3.0" ;
    owl:versionIRI <https://www.somusicvocabulary.org/music/2.3.0> ;
    owl:imports <https://w3id.org/semanticarts/ontology/gistCore> .

###############################################################################
# CLASSES — AGENTS & PEOPLE
###############################################################################

:MusicalAgent a owl:Class ;
    skos:prefLabel "Musical Agent"@en ;
    skos:scopeNote "Any agent — person or group — that creates or performs music."@en ;
    skos:definition "Any person or group that creates or performs music; the common parent of musical artists and musicians."@en ;
    .

# The person-side counterpart to :Band. What every producer, conductor, lyricist and
# engineer essentially IS — a human working in music — as distinct from what they DO,
# which is a :MusicalRole (see :hasRole). Producing is a job you can take up and put
# down; being a person is not. Roles are therefore categories, not classes, and this is
# the class they attach to. :Musician narrows it to those who actually perform.
:MusicalPerson a owl:Class ;
    rdfs:subClassOf :MusicalAgent ;
    rdfs:subClassOf gist:Person ;
    skos:prefLabel "Musical Person"@en ;
    skos:scopeNote "A human who works in music in any capacity — performing, producing, conducting, writing. Use :hasRole to say which."@en ;
    skos:definition "A musical agent that is an individual human being, as opposed to a group."@en ;
    :exampleInstance :GeorgeMartin, :RickRubin, :HerbertVonKarajan ;
    .

:MusicalArtist a owl:Class ;
    rdfs:subClassOf :MusicalAgent ;
    skos:prefLabel "Musical Artist"@en ;
    skos:scopeNote "An individual or group that performs music."@en ;
    skos:broader :Artist ;
    skos:related :MusicGenre ;
    skos:narrower :SoloArtist, :Band ;
    skos:definition "A musical artist is an individual or group that creates or performs music."@en ;
    :exampleInstance :PaulMcCartney, :KanyeWest, :SadeAdu, :BeyonceKnowles, :MilesDavis ;
    .

:SoloArtist a owl:Class ;
    rdfs:subClassOf :MusicalArtist ;
    rdfs:subClassOf :Musician ;
    skos:prefLabel "Solo Artist"@en ;
    skos:scopeNote "An individual musical artist who performs or records under their own name."@en ;
    skos:broader :MusicalArtist ;
    skos:definition "A solo artist is an individual who performs or records music independently."@en ;
    :exampleInstance :PaulMcCartney, :KanyeWest, :SadeAdu, :BeyonceKnowles, :MilesDavis, :BobMarley, :DavidBowie, :TaylorSwift, :MichaelJackson, :LudwigVanBeethoven ;
    .

:Band a owl:Class ;
    rdfs:subClassOf :MusicalArtist ;
    rdfs:subClassOf gist:Organization ;
    skos:prefLabel "Band"@en ;
    skos:scopeNote "A group of musicians who perform together under a collective name."@en ;
    skos:broader :MusicalArtist ;
    skos:narrower :RockBand, :JazzEnsemble, :Orchestra, :Choir ;
    skos:definition "A band is a group of musicians who perform or record together."@en ;
    :exampleInstance :TheBeatles, :Coldplay, :Nirvana, :LedZeppelin, :Radiohead, :TheRollingStones ;
    .

:RockBand a owl:Class ;
    rdfs:subClassOf :Band ;
    skos:prefLabel "Rock Band"@en ;
    skos:scopeNote "A band whose primary genre is rock music."@en ;
    skos:broader :Band ;
    skos:definition "A rock band is a musical group specializing in rock music."@en ;
    :exampleInstance :TheBeatles, :Nirvana, :LedZeppelin, :Radiohead, :TheRollingStones ;
    .

:JazzEnsemble a owl:Class ;
    rdfs:subClassOf :Band ;
    skos:prefLabel "Jazz Ensemble"@en ;
    skos:scopeNote "A group of musicians performing jazz music."@en ;
    skos:broader :Band ;
    skos:definition "A jazz ensemble is a group of musicians performing jazz music."@en ;
    :exampleInstance :MilesDavisTrio ;
    .

:Orchestra a owl:Class ;
    rdfs:subClassOf :Band ;
    skos:prefLabel "Orchestra"@en ;
    skos:scopeNote "A large ensemble of musicians, typically performing classical music."@en ;
    skos:broader :Band ;
    skos:definition "An orchestra is a large instrumental ensemble composed of strings, winds, brass, and percussion."@en ;
    :exampleInstance :BerlinPhilharmonic, :LondonSymphonyOrchestra ;
    .

:Choir a owl:Class ;
    rdfs:subClassOf :Band ;
    skos:prefLabel "Choir"@en ;
    skos:scopeNote "An organized group of singers."@en ;
    skos:broader :Band ;
    skos:definition "A choir is an organized group of singers who perform together."@en ;
    .

:Musician a owl:Class ;
    rdfs:subClassOf :MusicalPerson ;
    skos:prefLabel "Musician"@en ;
    skos:scopeNote "A person who plays a musical instrument or sings."@en ;
    skos:related :MusicalInstrument, :Band ;
    skos:definition "A musician is a person who practices music, either as a performer or composer."@en ;
    :exampleInstance :JohnLennon, :JimiHendrix, :YoYoMa ;
    .

:Composer a owl:Class ;
    rdfs:subClassOf :Musician ;
    skos:prefLabel "Composer"@en ;
    skos:scopeNote "A person who writes original music."@en ;
    skos:broader :Musician ;
    skos:definition "A composer is a musician who creates original musical works."@en ;
    :exampleInstance :LudwigVanBeethoven, :WolfgangAmadeusMozart, :JohannSebastianBach ;
    .

:Lyricist a owl:Class ;
    rdfs:subClassOf gist:Person ;
    skos:prefLabel "Lyricist"@en ;
    skos:scopeNote "A person who writes the words (lyrics) for songs."@en ;
    skos:related :Song ;
    skos:definition "A lyricist is a writer who specializes in writing song lyrics."@en ;
    :exampleInstance :BobDylan, :PaulMcCartney ;
    .

:MusicProducer a owl:Class ;
    rdfs:subClassOf gist:Person ;
    skos:prefLabel "Music Producer"@en ;
    skos:scopeNote "A person who oversees and manages the recording and production of music."@en ;
    skos:related :Album, :RecordLabel ;
    skos:definition "A music producer is responsible for overseeing the recording, mixing, and production of musical recordings."@en ;
    :exampleInstance :QuincyJones, :RickRubin, :GeorgeMartin ;
    .

:Conductor a owl:Class ;
    rdfs:subClassOf :Musician ;
    skos:prefLabel "Conductor"@en ;
    skos:scopeNote "A person who directs the performance of an orchestra or choir."@en ;
    skos:broader :Musician ;
    skos:related :Orchestra ;
    skos:definition "A conductor is a musician who leads an orchestra, choir, or other musical ensemble."@en ;
    :exampleInstance :HerbertVonKarajan, :LeonardBernstein ;
    .

###############################################################################
# CLASSES — MUSICAL ROLES (gist:Category pattern)
#
# A role is what an agent DOES, not what it IS. Producing, conducting, writing lyrics
# and composing are jobs — an agent can hold several at once (Quincy Jones held three)
# and can take them up or set them down without ceasing to be the same person. Modelling
# an anti-rigid property like that as a rigid OWL class is what forced the old dead ends:
# typed :MusicProducer, Quincy could not hold :hasInstrument (domain :Musician) or be the
# :performedBy of a work (range :MusicalArtist), because roles-as-classes made his other
# roles unsayable.
#
# So roles are gist:Category instances, reached by :hasRole. This is the same pattern the
# model already uses for genres (:MusicGenre / :hasGenre), place granularity (:PlaceType /
# :hasPlaceType) and collections (:CollectionType) — and it is what the style guide means
# by "prefer gist:isCategorizedBy over subclassing for type variation".
#
# The role INSTANCES (:ProducerRole, :ConductorRole, :LyricistRole, :ComposerRole) live in
# the ABox alongside the genre and :PlaceType individuals.
###############################################################################

:MusicalRole a owl:Class ;
    rdfs:subClassOf gist:Category ;
    skos:prefLabel "Musical Role"@en ;
    skos:scopeNote "A capacity in which an agent contributes to music. Attach with :hasRole; do not subclass agents by role."@en ;
    skos:definition "A category that classifies the capacity in which a musical agent contributes to music, such as producing, conducting, writing lyrics or composing."@en ;
    :exampleInstance :ProducerRole, :ConductorRole, :LyricistRole, :ComposerRole ;
    .

###############################################################################

:RecordLabel a owl:Class ;
    rdfs:subClassOf gist:Organization ;
    skos:prefLabel "Record Label"@en ;
    skos:scopeNote "A company that manages the production and distribution of music recordings."@en ;
    skos:related :Album, :MusicalArtist ;
    skos:definition "A record label is a brand or trademark of a music recording company."@en ;
    :exampleInstance :EMI, :SonyMusicEntertainment, :UniversalMusicGroup, :WarnerMusicGroup, :DefJamRecordings ;
    .

###############################################################################
# CLASSES — MUSICAL WORKS
###############################################################################

:MusicalWork a owl:Class ;
    rdfs:subClassOf gist:Content ;
    skos:prefLabel "Musical Work"@en ;
    skos:scopeNote "A creative work in the medium of music."@en ;
    skos:narrower :Song, :Album, :EP, :Composition, :Soundtrack ;
    skos:definition "A musical work is any creative work expressed in the form of music."@en ;
    .

:Song a owl:Class ;
    rdfs:subClassOf :MusicalWork ;
    skos:prefLabel "Song"@en ;
    skos:scopeNote "A short musical composition with vocals."@en ;
    skos:broader :MusicalWork ;
    skos:related :Album, :MusicalArtist, :Lyricist ;
    skos:definition "A song is a short musical composition intended to be sung, typically combining melody and lyrics."@en ;
    :exampleInstance :HeyJude, :BohemianRhapsody, :BillieJean, :SmokeOnTheWater, :ImagineSong, :NoWomanNoCry, :CryMeARiver ;
    .

:Album a owl:Class ;
    rdfs:subClassOf :MusicalWork ;
    skos:prefLabel "Album"@en ;
    skos:scopeNote "A collection of songs released as a single unit."@en ;
    skos:broader :MusicalWork ;
    skos:narrower :StudioAlbum, :LiveAlbum, :CompilationAlbum ;
    skos:related :Song, :MusicalArtist, :RecordLabel ;
    skos:definition "An album is a collection of audio recordings released as a single package."@en ;
    :exampleInstance :AbbeyRoad, :TheDarkSideOfTheMoon, :Thriller, :KindOfBlue, :Lemonade, :OkComputer ;
    .

:StudioAlbum a owl:Class ;
    rdfs:subClassOf :Album ;
    skos:prefLabel "Studio Album"@en ;
    skos:scopeNote "An album of original recordings made in a recording studio."@en ;
    skos:broader :Album ;
    skos:definition "A studio album consists of original material recorded in a professional recording studio."@en ;
    :exampleInstance :AbbeyRoad, :Thriller, :KindOfBlue, :Lemonade, :OkComputer ;
    .

:LiveAlbum a owl:Class ;
    rdfs:subClassOf :Album ;
    skos:prefLabel "Live Album"@en ;
    skos:scopeNote "An album recorded during a live performance."@en ;
    skos:broader :Album ;
    skos:definition "A live album is a recording made during a live performance rather than in a studio."@en ;
    .

:CompilationAlbum a owl:Class ;
    rdfs:subClassOf :Album ;
    skos:prefLabel "Compilation Album"@en ;
    skos:scopeNote "An album of songs drawn from multiple sources or artists."@en ;
    skos:broader :Album ;
    skos:definition "A compilation album consists of songs chosen from earlier releases or from various artists."@en ;
    .

:EP a owl:Class ;
    rdfs:subClassOf :MusicalWork ;
    skos:prefLabel "Extended Play (EP)"@en ;
    skos:scopeNote "A musical recording that contains more than a single but fewer tracks than a full album."@en ;
    skos:broader :MusicalWork ;
    skos:definition "An EP (Extended Play) is a music release that contains more tracks than a single but fewer than an album."@en ;
    .

:Composition a owl:Class ;
    rdfs:subClassOf :MusicalWork ;
    skos:prefLabel "Musical Composition"@en ;
    skos:scopeNote "A formal musical work, typically in the classical tradition."@en ;
    skos:broader :MusicalWork ;
    skos:narrower :Symphony, :Concerto, :Sonata, :Opera ;
    skos:related :Composer ;
    skos:definition "A musical composition is a formal musical work created by a composer."@en ;
    :exampleInstance :Symphony9Beethoven, :RequiemMozart ;
    .

:Symphony a owl:Class ;
    rdfs:subClassOf :Composition ;
    skos:prefLabel "Symphony"@en ;
    skos:scopeNote "An extended musical composition for full orchestra."@en ;
    skos:broader :Composition ;
    skos:definition "A symphony is an extended musical composition in Western classical music, scored for orchestra."@en ;
    :exampleInstance :Symphony9Beethoven ;
    .

:Concerto a owl:Class ;
    rdfs:subClassOf :Composition ;
    skos:prefLabel "Concerto"@en ;
    skos:scopeNote "A composition for a solo instrument and orchestra."@en ;
    skos:broader :Composition ;
    skos:definition "A concerto is a composition for one or more solo instruments and an orchestral ensemble."@en ;
    .

:Sonata a owl:Class ;
    rdfs:subClassOf :Composition ;
    skos:prefLabel "Sonata"@en ;
    skos:scopeNote "A composition for one or two instruments, typically in several movements."@en ;
    skos:broader :Composition ;
    skos:definition "A sonata is a composition for solo instrument, typically structured in multiple movements."@en ;
    .

:Opera a owl:Class ;
    rdfs:subClassOf :Composition ;
    skos:prefLabel "Opera"@en ;
    skos:scopeNote "A dramatic work set to music for singers and orchestra."@en ;
    skos:broader :Composition ;
    skos:definition "An opera is a form of theater in which music has a leading role, combining vocal and orchestral music with drama."@en ;
    .

:Soundtrack a owl:Class ;
    rdfs:subClassOf :MusicalWork ;
    skos:prefLabel "Soundtrack"@en ;
    skos:scopeNote "Music composed and recorded for a film, television show, or other media."@en ;
    skos:broader :MusicalWork ;
    skos:definition "A soundtrack is the recorded music accompanying and synchronized to a film, television show, or other visual media."@en ;
    .

###############################################################################
# CLASSES — GENRES
###############################################################################

:MusicGenre a owl:Class ;
    rdfs:subClassOf gist:Category ;
    skos:prefLabel "Music Genre"@en ;
    skos:scopeNote "A category of music characterized by a particular style, form, or content."@en ;
    skos:definition "A music genre is a conventional category that identifies musical compositions as belonging to a shared tradition or set of conventions."@en ;
    :exampleInstance :Rock, :Jazz, :Classical, :HipHop, :Blues, :Soul, :Pop, :Reggae ;
    .

###############################################################################
# CLASSES — INSTRUMENTS
###############################################################################

:MusicalInstrument a owl:Class ;
    rdfs:subClassOf gist:Equipment ;
    skos:prefLabel "Musical Instrument"@en ;
    skos:scopeNote "A device — or the human voice — used for the purpose of making music."@en ;
    skos:narrower :StringInstrument, :WindInstrument, :PercussionInstrument, :KeyboardInstrument, :ElectronicInstrument, :VocalInstrument ;
    skos:definition "A musical instrument is a device, or the human voice, created or used to make musical sounds."@en ;
    :exampleInstance :Guitar, :Piano, :Drums, :Violin, :Trumpet, :Saxophone, :Bass ;
    .

:StringInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "String Instrument"@en ;
    skos:scopeNote "An instrument that produces sound through vibrating strings."@en ;
    skos:broader :MusicalInstrument ;
    skos:narrower :PluckedString, :BowedString ;
    skos:definition "A string instrument is a musical instrument that produces sound by vibrating strings."@en ;
    :exampleInstance :Guitar, :Violin, :Cello, :Harp, :Banjo, :Bass ;
    .

:PluckedString a owl:Class ;
    rdfs:subClassOf :StringInstrument ;
    skos:prefLabel "Plucked String Instrument"@en ;
    skos:scopeNote "A string instrument played by plucking or strumming the strings."@en ;
    skos:broader :StringInstrument ;
    skos:definition "A plucked string instrument is played by plucking or strumming."@en ;
    :exampleInstance :Guitar, :Banjo, :Harp ;
    .

:BowedString a owl:Class ;
    rdfs:subClassOf :StringInstrument ;
    skos:prefLabel "Bowed String Instrument"@en ;
    skos:scopeNote "A string instrument played with a bow."@en ;
    skos:broader :StringInstrument ;
    skos:definition "A bowed string instrument is played using a bow drawn across the strings."@en ;
    :exampleInstance :Violin, :Cello, :DoubleBass ;
    .

:WindInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "Wind Instrument"@en ;
    skos:scopeNote "An instrument that produces sound through vibrating air in a tube."@en ;
    skos:broader :MusicalInstrument ;
    skos:narrower :BrassInstrument, :WoodwindInstrument ;
    skos:definition "A wind instrument is a musical instrument that produces sound by causing a body of air to vibrate."@en ;
    :exampleInstance :Trumpet, :Saxophone, :Flute, :Clarinet, :Tuba ;
    .

:BrassInstrument a owl:Class ;
    rdfs:subClassOf :WindInstrument ;
    skos:prefLabel "Brass Instrument"@en ;
    skos:scopeNote "A wind instrument made of brass or similar metal."@en ;
    skos:broader :WindInstrument ;
    skos:definition "A brass instrument is a musical instrument that produces sound by sympathetic vibration of air in a tubular resonator."@en ;
    :exampleInstance :Trumpet, :Trombone, :Tuba, :FrenchHorn ;
    .

:WoodwindInstrument a owl:Class ;
    rdfs:subClassOf :WindInstrument ;
    skos:prefLabel "Woodwind Instrument"@en ;
    skos:scopeNote "A wind instrument in which sound is produced by blowing against an edge or through a reed."@en ;
    skos:broader :WindInstrument ;
    skos:definition "A woodwind instrument is a musical instrument in which sound is produced by the vibration of a reed or the player's lips."@en ;
    :exampleInstance :Saxophone, :Flute, :Clarinet, :Oboe ;
    .

:PercussionInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "Percussion Instrument"@en ;
    skos:scopeNote "An instrument that produces sound by being struck, shaken, or scraped."@en ;
    skos:broader :MusicalInstrument ;
    skos:definition "A percussion instrument is a musical instrument that produces sound by being struck or scraped by a beater, scraped by hand, or struck against another instrument."@en ;
    :exampleInstance :Drums, :Xylophone, :Marimba, :Tambourine ;
    .

:KeyboardInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "Keyboard Instrument"@en ;
    skos:scopeNote "An instrument played using a keyboard of keys."@en ;
    skos:broader :MusicalInstrument ;
    skos:definition "A keyboard instrument is a musical instrument played using a keyboard, a row of levers which are pressed by the fingers."@en ;
    :exampleInstance :Piano, :Organ, :Harpsichord, :Synthesizer ;
    .

:ElectronicInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "Electronic Instrument"@en ;
    skos:scopeNote "An instrument that produces or modifies sound electronically."@en ;
    skos:broader :MusicalInstrument ;
    skos:definition "An electronic musical instrument uses electronic circuits to produce or modify sound."@en ;
    :exampleInstance :Synthesizer, :DrumMachine, :Theremin ;
    .

###############################################################################
# CLASSES — EVENTS & VENUES
###############################################################################

:MusicEvent a owl:Class ;
    rdfs:subClassOf gist:Event ;
    skos:prefLabel "Music Event"@en ;
    skos:scopeNote "A scheduled occasion at which music is performed."@en ;
    skos:narrower :Concert, :MusicFestival, :RecordingSession ;
    skos:definition "A music event is any organized occasion involving the performance or creation of music."@en ;
    .

:Concert a owl:Class ;
    rdfs:subClassOf :MusicEvent ;
    skos:prefLabel "Concert"@en ;
    skos:scopeNote "A live performance of music before an audience."@en ;
    skos:broader :MusicEvent ;
    skos:related :MusicalArtist, :Venue ;
    skos:definition "A concert is a live performance of music before an audience."@en ;
    :exampleInstance :TheBeatlesShea1965, :Woodstock1969Concert ;
    .

:MusicFestival a owl:Class ;
    rdfs:subClassOf :MusicEvent ;
    skos:prefLabel "Music Festival"@en ;
    skos:scopeNote "A community event with performances by multiple artists over multiple days."@en ;
    skos:broader :MusicEvent ;
    skos:related :MusicalArtist, :Venue ;
    skos:definition "A music festival is a community event oriented towards live music performances."@en ;
    :exampleInstance :Glastonbury, :Coachella, :Woodstock ;
    .

:RecordingSession a owl:Class ;
    rdfs:subClassOf :MusicEvent ;
    skos:prefLabel "Recording Session"@en ;
    skos:scopeNote "A period of time during which music is recorded in a studio."@en ;
    skos:broader :MusicEvent ;
    skos:related :Album, :MusicProducer ;
    skos:definition "A recording session is a period of time used in a recording studio to record music."@en ;
    .

:Venue a owl:Class ;
    rdfs:subClassOf :Place ;
    skos:prefLabel "Venue"@en ;
    skos:scopeNote "A place where music events are held."@en ;
    skos:related :Concert, :MusicFestival ;
    skos:definition "A venue is a place where a music event is held."@en ;
    :exampleInstance :Madison_Square_Garden, :RoyalAlbertHall, :CarnegieHall ;
    .

###############################################################################
# CLASSES — AWARDS, CHARTS & PLAYLISTS
###############################################################################

:MusicAward a owl:Class ;
    skos:prefLabel "Music Award"@en ;
    skos:scopeNote "An honor given in recognition of musical achievement."@en ;
    skos:related :MusicalArtist, :Album, :Song ;
    skos:definition "A music award is a recognition given to a musician, group, album, or song for musical excellence or commercial success."@en ;
    :exampleInstance :GrammyAward, :BritAward, :MercuryPrize, :MTV_VMA ;
    .

:MusicChart a owl:Class ;
    rdfs:subClassOf gist:Collection ;
    skos:prefLabel "Music Chart"@en ;
    skos:scopeNote "A ranked list of the most popular songs or albums for a given period."@en ;
    skos:related :Song, :Album ;
    skos:definition "A music chart is a ranked list of the most popular songs or albums based on various criteria such as sales, airplay, or streaming."@en ;
    :exampleInstance :Billboard_Hot100, :UK_Singles_Chart ;
    .

:Playlist a owl:Class ;
    rdfs:subClassOf gist:Collection ;
    skos:prefLabel "Playlist"@en ;
    skos:scopeNote "A curated collection of songs."@en ;
    skos:related :Song, :MusicalArtist ;
    skos:definition "A playlist is a list of songs or other audio tracks that are grouped together and played in sequence."@en ;
    .

# A curated grouping of related works (box set, anthology, compilation, thematic series).
# Generalises across work types — distinct from :Album (a release that is itself a work) and
# broader than :Playlist (songs only). Membership is the plain relation :collects (L1); the
# act-of-collecting event and time-indexed membership are deliberately deferred (see spec.md).
:WorkCollection a owl:Class ;
    rdfs:subClassOf gist:Collection ;
    skos:prefLabel "Work Collection"@en ;
    skos:scopeNote "Curated, identity-bearing grouping; not a query result. Derived 'related works' stay SPARQL/CQs. Kind carried by gist:isCategorizedBy a :CollectionType."@en ;
    skos:definition "A work collection is a curated collection that groups related musical works, such as a box set, anthology, compilation, or thematic series."@en ;
    :exampleInstance :GreatestRockAnthems ;
    .

:CollectionType a owl:Class ;
    rdfs:subClassOf gist:Category ;
    skos:prefLabel "Collection Type"@en ;
    skos:scopeNote "Collection-type individuals (:Anthology, :BoxSet, :Compilation, :ThematicCollection) live in the ABox; assign one to a :WorkCollection with gist:isCategorizedBy."@en ;
    skos:definition "A collection type is a category that classifies a work collection by its curatorial form, such as anthology, box set, compilation, or thematic series."@en ;
    :exampleInstance :Anthology, :BoxSet, :Compilation, :ThematicCollection ;
    .

###############################################################################
# CLASSES — MUSICAL ELEMENTS
###############################################################################

:MusicKey a owl:Class ;
    rdfs:subClassOf gist:Aspect ;
    skos:prefLabel "Music Key"@en ;
    skos:scopeNote "A group of pitches forming the basis of a music composition."@en ;
    skos:definition "A music key is a group of pitches, or scale, that forms the basis of a music composition."@en ;
    :exampleInstance :KeyC_Major, :KeyA_Minor, :KeyG_Major ;
    .

:TimeSignature a owl:Class ;
    rdfs:subClassOf gist:Aspect ;
    skos:prefLabel "Time Signature"@en ;
    skos:scopeNote "A notational convention specifying the number and value of beats per measure."@en ;
    skos:definition "A time signature is a notational convention used to specify how many beats are in each bar of music."@en ;
    :exampleInstance :FourFourTime, :ThreeFourTime, :SixEightTime ;
    .

:Tempo a owl:Class ;
    rdfs:subClassOf gist:Aspect ;
    skos:prefLabel "Tempo"@en ;
    skos:scopeNote "The speed at which a musical piece is played."@en ;
    skos:definition "Tempo is the speed or pace of a given piece of music, typically measured in beats per minute (BPM)."@en ;
    :exampleInstance :Andante, :Allegro, :Presto ;
    .

###############################################################################
# PROPERTIES
###############################################################################

# --- Artist / Agent Properties ---

:hasGenre a owl:ObjectProperty ;
    skos:prefLabel "has genre"@en ;
    skos:scopeNote "Associates a musical artist or work with a music genre."@en ;
    rdfs:domain [ owl:unionOf ( :MusicalArtist :MusicalWork ) ] ;
    rdfs:subPropertyOf gist:isCategorizedBy ;
    rdfs:range :MusicGenre ;
    skos:definition "Relates a musical artist or work to the genre(s) it belongs to."@en ;
    .

# The role dimension. Same shape as :hasGenre above: a sub-property of gist:isCategorizedBy
# ranging over a gist:Category subclass. An agent may hold any number of roles at once —
# that is the whole point, and it is what roles-as-classes could not express.
:hasRole a owl:ObjectProperty ;
    skos:prefLabel "has role"@en ;
    skos:scopeNote "Associates a musical agent with a capacity in which they contribute — producing, conducting, writing lyrics, composing. Repeatable: an agent may hold several roles."@en ;
    rdfs:domain :MusicalAgent ;
    rdfs:subPropertyOf gist:isCategorizedBy ;
    rdfs:range :MusicalRole ;
    skos:definition "Relates a musical agent to the role(s) in which they contribute to music."@en ;
    .

:hasMember a owl:ObjectProperty ;
    skos:prefLabel "has member"@en ;
    skos:scopeNote "Associates a band with its individual members."@en ;
    rdfs:domain :Band ;
    rdfs:range :Musician ;
    owl:inverseOf :isMemberOf ;
    skos:definition "Relates a band to the musicians who are members of it."@en ;
    .

:isMemberOf a owl:ObjectProperty ;
    skos:prefLabel "is member of"@en ;
    skos:scopeNote "Associates a musician with a band they belong to."@en ;
    rdfs:domain :Musician ;
    rdfs:range :Band ;
    owl:inverseOf :hasMember ;
    .

:collaboratesWith a owl:ObjectProperty, owl:SymmetricProperty ;
    skos:prefLabel "collaborates with"@en ;
    skos:scopeNote "Associates two music-making agents who have worked together."@en ;
    rdfs:domain :MusicalAgent ;
    rdfs:range :MusicalAgent ;
    skos:definition "Relates a musical agent to another agent with whom they have collaborated."@en ;
    .

:isSignedTo a owl:ObjectProperty ;
    skos:prefLabel "is signed to"@en ;
    skos:scopeNote "Associates a musical artist with their record label."@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range :RecordLabel ;
    owl:inverseOf :hasSigned ;
    skos:definition "Relates a musical artist to the record label they are contracted with."@en ;
    .

:hasSigned a owl:ObjectProperty ;
    skos:prefLabel "has signed"@en ;
    skos:scopeNote "Associates a record label with an artist they have contracted."@en ;
    rdfs:domain :RecordLabel ;
    rdfs:range :MusicalArtist ;
    owl:inverseOf :isSignedTo ;
    .

:hasAward a owl:ObjectProperty ;
    skos:prefLabel "has award"@en ;
    skos:scopeNote "Associates an artist or work with an award they have received."@en ;
    rdfs:domain [ owl:unionOf ( :MusicalArtist :MusicalWork ) ] ;
    rdfs:range :MusicAward ;
    skos:definition "Relates a musical artist or work to an award they have received."@en ;
    .

:originatesFrom a owl:ObjectProperty ;
    skos:prefLabel "originates from"@en ;
    skos:scopeNote "The geographic location where the artist originates."@en ;
    rdfs:domain :MusicalAgent ;
    rdfs:range :Place ;
    .

:startsCareerIn a owl:DatatypeProperty ;
    skos:prefLabel "starts career in"@en ;
    skos:scopeNote "The year in which the artist began their professional music career."@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range xsd:gYear ;
    .

:speaksLanguage a owl:DatatypeProperty ;
    skos:prefLabel "speaks language"@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range xsd:string ;
    .

:hasInstrument a owl:ObjectProperty ;
    skos:prefLabel "has instrument"@en ;
    skos:scopeNote "Associates a musician with an instrument they play."@en ;
    rdfs:domain :Musician ;
    rdfs:range :MusicalInstrument ;
    skos:definition "Relates a musician to the instrument(s) they play."@en ;
    .

:nationalityOf a owl:DatatypeProperty ;
    skos:prefLabel "nationality"@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range xsd:string ;
    .

# --- Musical Work Properties ---

:performedBy a owl:ObjectProperty ;
    skos:prefLabel "performed by"@en ;
    skos:scopeNote "Associates a musical work with the artist who performs it."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :MusicalArtist ;
    owl:inverseOf :performs ;
    skos:definition "Relates a song or work to the artist who performs it."@en ;
    .

:performs a owl:ObjectProperty ;
    skos:prefLabel "performs"@en ;
    skos:scopeNote "Associates an artist with a musical work they perform."@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range :MusicalWork ;
    owl:inverseOf :performedBy ;
    .

:composedBy a owl:ObjectProperty ;
    skos:prefLabel "composed by"@en ;
    skos:scopeNote "Associates a musical work with its composer."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :Composer ;
    skos:definition "Relates a musical work to the composer who created it."@en ;
    .

:writtenBy a owl:ObjectProperty ;
    skos:prefLabel "written by"@en ;
    skos:scopeNote "Associates a song with its lyricist."@en ;
    rdfs:domain :Song ;
    rdfs:range :Lyricist ;
    skos:definition "Relates a song to the lyricist who wrote its lyrics."@en ;
    .

:producedBy a owl:ObjectProperty ;
    skos:prefLabel "produced by"@en ;
    skos:scopeNote "Associates a musical work with its producer."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :MusicProducer ;
    skos:definition "Relates a musical work to the producer who oversaw its production."@en ;
    .

:releasedBy a owl:ObjectProperty ;
    skos:prefLabel "released by"@en ;
    skos:scopeNote "Associates a musical work with the record label that released it."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :RecordLabel ;
    skos:definition "Relates an album or song to the record label that released it."@en ;
    .

:hasTrack a owl:ObjectProperty ;
    skos:prefLabel "has track"@en ;
    skos:scopeNote "Associates an album with the songs it contains."@en ;
    rdfs:domain :Album ;
    rdfs:range :Song ;
    owl:inverseOf :belongsToAlbum ;
    skos:definition "Relates an album to the tracks it contains."@en ;
    .

:belongsToAlbum a owl:ObjectProperty ;
    skos:prefLabel "belongs to album"@en ;
    skos:scopeNote "Associates a song with the album it is on."@en ;
    rdfs:domain :Song ;
    rdfs:range :Album ;
    owl:inverseOf :hasTrack ;
    .

# Plain membership relation for :WorkCollection (L1), mirroring gist:isMemberOf conceptually.
# Deliberately NOT declared owl:inverseOf gist:isMemberOf: coupling a domain-constrained local
# property to that shared upper property leaks :WorkCollection onto every gist:isMemberOf target
# and makes gist:UnitGroup / IntergovernmentalOrganization / GeoRoute unsatisfiable (caught by
# `make reason`). Atemporal: no "when added" / "who curated" — L2/L3 deferred (see sdd/spec.md).
:collects a owl:ObjectProperty ;
    skos:prefLabel "collects"@en ;
    rdfs:domain :WorkCollection ;
    rdfs:range :MusicalWork ;
    skos:definition "Relates a work collection to a musical work it includes."@en ;
    .

:releasedIn a owl:DatatypeProperty ;
    skos:prefLabel "released in"@en ;
    skos:scopeNote "The year a musical work was released."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range xsd:gYear ;
    .

:hasDuration a owl:DatatypeProperty ;
    skos:prefLabel "has duration"@en ;
    skos:scopeNote "The duration of a musical work in seconds."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range xsd:decimal ;
    .

:hasTrackNumber a owl:DatatypeProperty ;
    skos:prefLabel "has track number"@en ;
    rdfs:domain :Song ;
    rdfs:range xsd:integer ;
    .

:inKey a owl:ObjectProperty ;
    skos:prefLabel "in key"@en ;
    skos:scopeNote "Associates a musical work with its key."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :MusicKey ;
    .

:hasTempo a owl:ObjectProperty ;
    skos:prefLabel "has tempo"@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :Tempo ;
    .

:hasTimeSignature a owl:ObjectProperty ;
    skos:prefLabel "has time signature"@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :TimeSignature ;
    .

# --- Event Properties ---

:headlinedBy a owl:ObjectProperty ;
    skos:prefLabel "headlined by"@en ;
    skos:scopeNote "Associates an event with the headlining artist."@en ;
    rdfs:domain :MusicEvent ;
    rdfs:range :MusicalArtist ;
    skos:definition "Relates a concert or festival to its headline performer."@en ;
    .

:heldAt a owl:ObjectProperty ;
    skos:prefLabel "held at"@en ;
    skos:scopeNote "Associates a music event with its venue."@en ;
    rdfs:domain :MusicEvent ;
    rdfs:range :Venue ;
    .

:heldOn a owl:DatatypeProperty ;
    skos:prefLabel "held on"@en ;
    skos:scopeNote "The date on which a music event occurred."@en ;
    rdfs:domain :MusicEvent ;
    rdfs:range xsd:date ;
    .

:hasAttendance a owl:DatatypeProperty ;
    skos:prefLabel "has attendance"@en ;
    rdfs:domain :MusicEvent ;
    rdfs:range xsd:integer ;
    .

# --- Chart / Award Properties ---

:peaksAt a owl:DatatypeProperty ;
    skos:prefLabel "peaks at"@en ;
    skos:scopeNote "The peak chart position of a song or album."@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range xsd:integer ;
    .

:chartedIn a owl:ObjectProperty ;
    skos:prefLabel "charted in"@en ;
    rdfs:domain :MusicalWork ;
    rdfs:range :MusicChart ;
    .

:awardCategory a owl:DatatypeProperty ;
    skos:prefLabel "award category"@en ;
    rdfs:domain :MusicAward ;
    rdfs:range xsd:string ;
    .

:awardYear a owl:DatatypeProperty ;
    skos:prefLabel "award year"@en ;
    rdfs:domain :MusicAward ;
    rdfs:range xsd:gYear ;
    .

# --- Shared annotation property ---

:exampleInstance a owl:AnnotationProperty ;
    skos:prefLabel "example instance"@en ;
    skos:scopeNote "Links a class to an example individual of that class."@en ;
    .

# Declared as an annotation property so its associative use on classes stays within OWL 2 DL.
skos:related a owl:AnnotationProperty ;
    skos:prefLabel "related"@en ;
    .

skos:prefLabel a owl:AnnotationProperty .
skos:definition a owl:AnnotationProperty .
skos:scopeNote a owl:AnnotationProperty .

###############################################################################
# STRUCTURAL-FIX ADDITIONS (Artefact 4 - Modeller Dialogue)
###############################################################################

# --- Genre: gist:Category pattern ---

:TopLevelGenre a owl:Class ;
    rdfs:subClassOf :MusicGenre ;
    skos:prefLabel "Top-Level Genre"@en ;
    skos:definition "A music genre that is a root of the genre hierarchy (no broader genre)."@en ;
    .

:hasBroaderGenre a owl:ObjectProperty, owl:TransitiveProperty ;
    skos:prefLabel "has broader genre"@en ;
    rdfs:domain :MusicGenre ;
    rdfs:range :MusicGenre ;
    skos:definition "Relates a subgenre to a broader genre; transitive, so closure reaches all ancestors."@en ;
    .

# --- Geography: structured place graph ---

:Place a owl:Class ;
    rdfs:subClassOf gist:GeoRegion ;
    skos:prefLabel "Place"@en ;
    skos:definition "A geographic location at which an agent originates or an organisation, venue, or event is situated."@en ;
    .

# Granularity is carried by gist:Category typing (:hasPlaceType), not by subclassing,
# mirroring the genre model. City/Region/Nation/Continent are :PlaceType individuals
# in the ABox; :broaderPlaceType orders them finest-to-coarsest for level queries.
:PlaceType a owl:Class ;
    rdfs:subClassOf gist:Category ;
    skos:prefLabel "Place Type"@en ;
    skos:scopeNote "Place-type individuals (:City, :Region, :Nation, :Continent) live in the ABox; assign one to a :Place with :hasPlaceType."@en ;
    skos:definition "A place type is a category that classifies a place by its geographic granularity, such as city, region, nation, or continent."@en ;
    :exampleInstance :City, :Region, :Nation, :Continent ;
    .

:locatedIn a owl:ObjectProperty, owl:TransitiveProperty ;
    skos:prefLabel "located in"@en ;
    rdfs:range :Place ;
    skos:definition "Relates an organisation, venue, event, or place to a containing place; transitive for regional roll-up."@en ;
    .

:hasPlaceType a owl:ObjectProperty ;
    rdfs:subPropertyOf gist:isCategorizedBy ;
    skos:prefLabel "has place type"@en ;
    rdfs:domain :Place ;
    rdfs:range :PlaceType ;
    skos:definition "Relates a place to its granularity category — city, region, nation, or continent."@en ;
    .

:broaderPlaceType a owl:ObjectProperty, owl:TransitiveProperty ;
    skos:prefLabel "has broader place type"@en ;
    rdfs:domain :PlaceType ;
    rdfs:range :PlaceType ;
    skos:definition "Relates a finer place type to the next coarser one (city → region → nation → continent); transitive, so closure reaches every coarser level."@en ;
    .

# --- Time: bornOn replaces the removed hasAge ---

:bornOn a owl:DatatypeProperty ;
    skos:prefLabel "born on"@en ;
    rdfs:domain :MusicalAgent ;
    rdfs:range xsd:date ;
    skos:definition "The date on which an agent was born."@en ;
    .

# --- Time: artist activity interval (the canonical era signal). :startsCareerIn
#     is the narrower "first professional year" and is subordinate to :activeFrom. ---

:activeFrom a owl:DatatypeProperty ;
    skos:prefLabel "active from"@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range xsd:gYear ;
    skos:definition "The year an artist's active period began; the start of the activity interval used for era-overlap queries (CQ-13)."@en ;
    .

:activeUntil a owl:DatatypeProperty ;
    skos:prefLabel "active until"@en ;
    rdfs:domain :MusicalArtist ;
    rdfs:range xsd:gYear ;
    skos:scopeNote "Omit for currently-active artists; era-overlap queries treat a missing value as open-ended (still active)."@en ;
    skos:definition "The year an artist's active period ended; absent means the artist is still active (an open interval)."@en ;
    .

###############################################################################
# v2.1 — VOCALS + CATALOG COMPLETENESS
###############################################################################

# --- Voice as an instrument (the body's natural instrument) ---
:VocalInstrument a owl:Class ;
    rdfs:subClassOf :MusicalInstrument ;
    skos:prefLabel "Vocal Instrument"@en ;
    skos:definition "A musical instrument that is the human singing voice."@en ;
    .

###############################################################################
# v2.2 — TIME PERIODS, MULTI-LEVEL GEOGRAPHY & HISTORICAL EVENTS
###############################################################################

# --- Historical events (for "came of age during …" discovery, CQ-15) ---
# A period event with a start/end interval and a location. Artists are related to
# it by *derivation* (birth-date age-window overlap + origin within its place),
# not by an asserted edge — see docs/competency-questions.md CQ-15.
:HistoricalEvent a owl:Class ;
    rdfs:subClassOf gist:HistoricalEvent ;
    skos:prefLabel "Historical Event"@en ;
    skos:scopeNote "Dated with gist:actualStartDate / gist:actualEndDate (xsd:date) and situated with :locatedIn a :Place. Boundary dates are sourced editorial claims, not exact facts."@en ;
    skos:definition "A historical event is a significant real-world occurrence spanning a bounded time interval that may shape the artists who come of age during it."@en ;
    :exampleInstance :AmericanCivilRightsMovement, :IrishWarOfIndependence ;
    .
