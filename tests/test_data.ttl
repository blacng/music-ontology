@prefix : <https://www.somusicvocabulary.org/music#> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

###############################################################################
# SYNTHETIC TEST DATA — Artefact 5 (Test Data + CQ Tests)
#
# A small, controlled fixture with obviously-synthetic identifiers (:TST_*).
# Loaded ALONGSIDE music_vocabulary_comprehensive.ttl (which supplies the TBox
# plus the genre / instrument / place reference individuals it reuses).
#
# Designed so every CQ has at least one YES-instance and one NO-instance.
# Edge cases: missing optionals (:TST_SoloEmpty), boundary chart position
# (:TST_Song1 peaksAt 1), multi-valued genre (:TST_SoloA), dual-role agent
# (:TST_MusM is a SoloArtist AND a band member — the boundary-fix case).
###############################################################################

# --- Places ---
:TST_CountryZ a :Place ; :hasPlaceType :Nation ; rdfs:label "Testland"@en ; .
:TST_CityX a :Place ; :hasPlaceType :City ; rdfs:label "Test City X"@en ; :locatedIn :TST_CountryZ ; .
:TST_CityY a :Place ; :hasPlaceType :City ; rdfs:label "Test City Y"@en ; :locatedIn :TST_CountryZ ; .

# --- Labels / charts / awards / producers ---
:TST_Label1 a :RecordLabel ; rdfs:label "Test Label One"@en ; :locatedIn :TST_CityX ; .
:TST_Label2 a :RecordLabel ; rdfs:label "Test Label Two"@en ; .
:TST_Chart1 a :MusicChart ; rdfs:label "Test Chart"@en ; .
:TST_Award1 a :MusicAward ; rdfs:label "Test Award"@en ; .
:TST_Producer1 a :MusicalPerson ;
    :hasRole :ProducerRole ; rdfs:label "Test Producer One"@en ; .
:TST_Producer2 a :MusicalPerson ;
    :hasRole :ProducerRole ; rdfs:label "Test Producer Two"@en ; .

# CQ-17: an agent holding more than one role. The catalogue asserts roles exactly this way
# (:QuincyJones holds three), so the fixture models the data as the catalogue does — it does
# not restate an entailment the catalogue never asserts.
:TST_MultiRole a :MusicalPerson ;
    :hasRole :ProducerRole, :ComposerRole ;
    rdfs:label "Test Multi-Role Agent"@en ; .

# --- Solo artists (SoloArtist ⊑ MusicalArtist ⊑ MusicalAgent, and ⊑ Musician) ---
:TST_SoloA a :SoloArtist ;
    rdfs:label "Test Solo A"@en ;
    :hasGenre :Rock, :Pop ;           # multi-valued → genre-spanning (CQ-6)
    :hasInstrument :Guitar ;
    :isSignedTo :TST_Label1 ;
    :collaboratesWith :TST_SoloB ;
    :originatesFrom :TST_CityX ;
    :bornOn "1970"^^xsd:gYear ;
    :startsCareerIn "1983"^^xsd:gYear ;
    :hasAward :TST_Award1 ;
    .

:TST_SoloB a :SoloArtist ;
    rdfs:label "Test Solo B"@en ;
    :hasGenre :Rock ;                  # shares Rock with A; only 1 top genre
    :hasInstrument :Piano ;            # different instrument family from A
    :isSignedTo :TST_Label1 ;          # labelmate of A (CQ-3)
    :originatesFrom :TST_CityX ;       # same scene as A (CQ-12)
    :startsCareerIn "1984"^^xsd:gYear ;
    .

:TST_SoloC a :SoloArtist ;
    rdfs:label "Test Solo C"@en ;
    :hasGenre :Jazz ;                  # shares nothing with A → NO-instance
    :hasInstrument :Saxophone ;
    :isSignedTo :TST_Label2 ;
    :originatesFrom :TST_CityY ;
    :startsCareerIn "1985"^^xsd:gYear ;
    .

:TST_SoloEmpty a :SoloArtist ;
    rdfs:label "Test Solo Empty"@en ;  # edge case: missing optional properties
    .

# --- Musicians / band ---
# CQ-11's link to :TST_SoloWork is asserted work-side only (:TST_SoloWork :performedBy :TST_MusM),
# mirroring the catalogue. Asserting :performs here too would restate an owl:inverseOf entailment
# and let CQ-11 pass on data the catalogue cannot supply.
:TST_MusM a :SoloArtist ;             # dual role: solo artist AND band member
    rdfs:label "Test Musician M"@en ;
    :hasGenre :Rock ;
    :hasInstrument :Guitar ;          # same instrument as SoloA (CQ-5)
    :isMemberOf :TST_BandX ;
    .

:TST_MusN a :Musician ;              # pure musician (no solo work)
    rdfs:label "Test Musician N"@en ;
    :hasInstrument :Drums ;
    :isMemberOf :TST_BandX ;
    .

:TST_MusBass a :Musician ;
    rdfs:label "Test Musician Bass"@en ;
    :hasInstrument :Bass ;            # PluckedString family, like Guitar (CQ-5)
    :isMemberOf :TST_BandAlt ;
    .

:TST_BandX a :RockBand ;
    rdfs:label "Test Band X"@en ;
    :hasGenre :Rock ;
    :isSignedTo :TST_Label1 ;
    :hasMember :TST_MusM, :TST_MusN ;
    :originatesFrom :TST_CityX ;
    .

:TST_BandAlt a :RockBand ;
    rdfs:label "Test Band Alt"@en ;
    :hasGenre :AlternativeRock ;       # subgenre of Rock → transitive browse (CQ-9)
    :hasMember :TST_MusBass ;
    .

# --- Works ---
:TST_Album1 a :StudioAlbum ;
    rdfs:label "Test Album One"@en ;
    :performedBy :TST_SoloA ;
    :producedBy :TST_Producer1 ;
    :releasedBy :TST_Label1 ;
    :releasedIn "1985"^^xsd:gYear ;
    :hasGenre :Rock ;
    :hasTrack :TST_Song1 ;
    .

:TST_Album2 a :StudioAlbum ;
    rdfs:label "Test Album Two"@en ;
    :performedBy :TST_SoloB ;
    :producedBy :TST_Producer1 ;       # same producer as Album1 → lineage (CQ-8)
    :releasedIn "1987"^^xsd:gYear ;    # same decade as Album1 (CQ-4)
    :hasGenre :Rock ;
    .

:TST_Album3 a :StudioAlbum ;
    rdfs:label "Test Album Three"@en ;
    :performedBy :TST_SoloC ;
    :producedBy :TST_Producer2 ;       # different producer → NO-instance (CQ-8)
    :releasedIn "1999"^^xsd:gYear ;
    :hasGenre :Jazz ;
    .

:TST_Song1 a :Song ;
    rdfs:label "Test Song One"@en ;
    :performedBy :TST_SoloA ;
    :belongsToAlbum :TST_Album1 ;
    :releasedIn "1985"^^xsd:gYear ;
    :hasGenre :Rock ;
    :peaksAt 1 ;                        # boundary: #1 hit (CQ-10)
    :chartedIn :TST_Chart1 ;
    .

:TST_Song2 a :Song ;
    rdfs:label "Test Song Two"@en ;
    :performedBy :TST_SoloB ;
    :releasedIn "1985"^^xsd:gYear ;
    :hasGenre :Rock ;
    :peaksAt 5 ;                        # not #1 → NO-instance (CQ-10)
    :chartedIn :TST_Chart1 ;
    .

:TST_Song1969 a :Song ;
    rdfs:label "Test Song 1969"@en ;
    :performedBy :TST_SoloA ;
    :releasedIn "1969"^^xsd:gYear ;    # same genre as Album1 but wrong decade (CQ-4 NO)
    :hasGenre :Rock ;
    .

:TST_SoloWork a :Song ;
    rdfs:label "Test Solo Work"@en ;
    :performedBy :TST_MusM ;
    :releasedIn "1990"^^xsd:gYear ;
    :hasGenre :Rock ;
    .

###############################################################################
# v2.2 FIXTURES — ERA OVERLAP (CQ-13), MULTI-LEVEL GEOGRAPHY (CQ-14),
#                 CAME-OF-AGE DURING A HISTORICAL EVENT (CQ-15)
###############################################################################

# --- CQ-13: activity-interval overlap + shared top-level genre ---
# Seed :TST_Era90sA (active 1991–1998, Rock). Overlap = A.from ≤ B.until ∧ B.from ≤ A.until.
:TST_Era90sA a :SoloArtist ;
    rdfs:label "Test Era 90s A"@en ;
    :hasGenre :Rock ;
    :activeFrom "1991"^^xsd:gYear ; :activeUntil "1998"^^xsd:gYear ;
    .
:TST_Era90sB a :SoloArtist ;             # overlaps seed era AND shares Rock → YES
    rdfs:label "Test Era 90s B"@en ;
    :hasGenre :Rock ;
    :activeFrom "1995"^^xsd:gYear ; :activeUntil "2003"^^xsd:gYear ;
    .
:TST_Era80s a :SoloArtist ;              # Rock but no era overlap (1980–1988) → NO
    rdfs:label "Test Era 80s"@en ;
    :hasGenre :Rock ;
    :activeFrom "1980"^^xsd:gYear ; :activeUntil "1988"^^xsd:gYear ;
    .
:TST_Era90sJazz a :SoloArtist ;          # era overlaps seed but different genre → NO
    rdfs:label "Test Era 90s Jazz"@en ;
    :hasGenre :Jazz ;
    :activeFrom "1992"^^xsd:gYear ; :activeUntil "2000"^^xsd:gYear ;
    .

# --- CQ-14: multi-level geographic peers (share an ancestor at a chosen level) ---
# A second continent branch gives a same-continent-but-different-nation NO-instance
# for the nation-level test.
:TST_ContinentQ a :Place ; :hasPlaceType :Continent ; rdfs:label "Test Continent Q"@en ; .
:TST_CountryW   a :Place ; :hasPlaceType :Nation ; rdfs:label "Test Country W"@en ; :locatedIn :TST_ContinentQ ; .
:TST_CityW      a :Place ; :hasPlaceType :City   ; rdfs:label "Test City W"@en ;    :locatedIn :TST_CountryW ; .
:TST_CountryZ   :locatedIn :TST_ContinentQ .     # Testland now rolls up to continent Q

:TST_GeoFar a :SoloArtist ;              # same continent as seed, different nation → nation-level NO
    rdfs:label "Test Geo Far"@en ;
    :hasGenre :Rock ;
    :originatesFrom :TST_CityW ;
    .

# --- CQ-15: came of age during a historical event (derived by birth-date + place) ---
# Event window [1960,1968] in Testland. Age window = [born+15, born+25]; a candidate
# qualifies iff that window overlaps the event AND their origin :locatedIn* the event place.
:TST_EventE a :HistoricalEvent ;
    rdfs:label "Test Event E"@en ;
    gist:actualStartDate "1960-01-01"^^xsd:date ;
    gist:actualEndDate   "1968-12-31"^^xsd:date ;
    :locatedIn :TST_CountryZ ;
    .
:TST_ComeOfAge a :SoloArtist ;           # born 1948 → window [1963,1973] overlaps; origin in place → YES
    rdfs:label "Test Came Of Age"@en ;
    :hasGenre :Rock ;
    :bornOn "1948"^^xsd:gYear ;
    :originatesFrom :TST_CityX ;
    .
:TST_TooYoung a :SoloArtist ;            # born 1965 → window [1980,1990] no overlap → NO
    rdfs:label "Test Too Young"@en ;
    :hasGenre :Rock ;
    :bornOn "1965"^^xsd:gYear ;
    :originatesFrom :TST_CityX ;
    .
:TST_WrongPlace a :SoloArtist ;          # right age but origin outside the event place → NO
    rdfs:label "Test Wrong Place"@en ;
    :hasGenre :Rock ;
    :bornOn "1948"^^xsd:gYear ;
    :originatesFrom :TST_CityW ;
    .

###############################################################################
# v2.3 FIXTURE — WORK COLLECTION BROWSE (CQ-16)
###############################################################################
:TST_CollType a :CollectionType ; rdfs:label "Test Collection Type"@en ; .
:TST_Collection a :WorkCollection ;      # collects two works; a third work is NOT collected
    rdfs:label "Test Work Collection"@en ;
    gist:isCategorizedBy :TST_CollType ;
    :collects :TST_Album1, :TST_Song1 ;
    .
